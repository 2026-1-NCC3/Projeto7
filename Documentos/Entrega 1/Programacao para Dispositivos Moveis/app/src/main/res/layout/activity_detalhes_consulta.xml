<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Detalhes da Consulta"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_margin="16dp"/>

    <LinearLayout
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quarta-feira\n25 de Abril"
            android:textStyle="bold"/>

        <TextView
            android:text="Horário: 10:00 - 11:00"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginHorizontal="16dp"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Anotações"
            android:textStyle="bold"/>

        <TextView
            android:text="• Foco na correção da postura cervical\n• Exercícios de relaxamento"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnVerTarefas"
        android:text="VER TAREFAS"
        android:layout_margin="16dp"
        android:backgroundTint="#6EC1C6"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnMensagem"
        android:text="ENVIAR MENSAGEM"
        android:layout_marginHorizontal="16dp"
        android:backgroundTint="#CCCCCC"/>

</LinearLayout>