<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tarefas de Casa"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#6EC1C6"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 Exercícios Atribuídos"
            android:layout_marginTop="8dp"/>

        <!-- Exercício 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/img_exercicio1"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alongamento de Trapézio"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 1 sessões realizadas"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnPlay1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circulo"
                android:src="@drawable/ic_play"
                android:scaleType="center"
                android:contentDescription="Play"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>

        </LinearLayout>

        <!-- Exercício 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/img_exercicio2"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fortalecimento dos Paravertebrais"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 1 sessões realizadas"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnPlay2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_play"
                android:background="@null"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnMensagem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENVIAR MENSAGEM"
            android:layout_marginTop="20dp"
            android:backgroundTint="#6EC1C6"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>