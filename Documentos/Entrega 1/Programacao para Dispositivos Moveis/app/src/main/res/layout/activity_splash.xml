<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/branco">

    <ImageView
        android:id="@+id/img_bg"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:scaleType="centerCrop" />
        <!-- android:src="@drawable/bg_splash"
        android:layout_alignParentTop="true" -->
    <!-- preciso colocar as ondas -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="60dp" />
        <!--android:src="@drawable/shape_wave"
        android:layout_below="@id/img_bg"
        android:layout_marginTop="-30dp" -->

    <ImageView
        android:id="@+id/img_logo"
        android:layout_width="285dp"
        android:layout_height="219dp"
        android:layout_alignParentTop="true"
        android:layout_marginTop="460dp"
        android:contentDescription="Logo Maya Yamamoto RPG"
        android:src="@drawable/logo_semfundo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerInParent="true"
        android:layout_marginTop="300dp"
        android:paddingHorizontal="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, que bom ter você por aqui!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/cinza_escuro"
            android:layout_gravity="center"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Durante a sua avaliação gratuita, a Dra. cadastrou seus dados no nosso sistema, ou seja, você não precisa efetuar cadastro! Clique no botão abaixo para acessar o seu portal!"
            android:textSize="14sp"
            android:textColor="@color/cinza_medio"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:lineSpacingMultiplier="1.4" />

        <Button
            android:id="@+id/btn_vamos_la"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_vamos_la"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/preto"
            android:backgroundTint="@color/marrom_botao"
            android:layout_marginTop="40dp"
            android:cornerRadius="12dp" />
    </LinearLayout>

</RelativeLayout>


