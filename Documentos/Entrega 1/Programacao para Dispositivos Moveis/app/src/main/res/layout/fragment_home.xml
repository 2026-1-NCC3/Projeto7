<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundo_cinza">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/teal_principal">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
                <!-- android:src="@drawable/bg_header"
                android:scaleType="centerCrop"
                android:alpha="0.6" -->

            <ImageView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:src="@drawable/logo_semfundo"
                android:layout_alignParentTop="true"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:contentDescription="Logo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/txt_saudacao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Olá, Paciente!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/branco" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como está se sentindo hoje?"
                    android:textSize="14sp"
                    android:textColor="@color/branco" />
            </LinearLayout>
        </RelativeLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:padding="16dp"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_agendamentos"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="6dp"
                android:text="Agendamentos"
                android:textSize="13sp"
                android:textColor="@color/cinza_escuro"
                android:backgroundTint="@color/branco"
                android:drawableTop="@drawable/calendar"
                android:drawablePadding="6dp" />

            <Button
                android:id="@+id/btn_progresso"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="6dp"
                android:text="Seu Progresso"
                android:textSize="13sp"
                android:textColor="@color/cinza_escuro"
                android:backgroundTint="@color/branco"
                android:drawableTop="@drawable/progress"
                android:drawablePadding="6dp" />

            <Button
                android:id="@+id/btn_exercicios"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="6dp"
                android:text="Meus Exercícios"
                android:textSize="13sp"
                android:textColor="@color/cinza_escuro"
                android:backgroundTint="@color/branco"
                android:drawableTop="@drawable/exercise"
                android:drawablePadding="6dp" />

            <Button
                android:id="@+id/btn_mensagens"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="6dp"
                android:text="Mensagens"
                android:textSize="13sp"
                android:textColor="@color/cinza_escuro"
                android:backgroundTint="@color/branco"
                android:drawableTop="@drawable/message"
                android:drawablePadding="6dp" />

        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Próximo agendamento"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/cinza_escuro"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/branco">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/img_foto_dra"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/foto_dra"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
        <!--android:background="@drawable/shape_circle"
       android:scaleType="centerCrop" -->

   <LinearLayout
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:orientation="vertical"
       android:layout_toEndOf="@id/img_foto_dra"
       android:layout_marginStart="12dp"
       android:layout_centerVertical="true">

       <TextView
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="Terça-Feira, 21 de Abril"
           android:textSize="13sp"
           android:textStyle="bold"
           android:textColor="@color/cinza_escuro" />

       <TextView
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="Maya Yamamoto"
           android:textSize="12sp"
           android:textColor="@color/cinza_medio" />

       <TextView
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="⏰ 10:00h – 12:00h"
           android:textSize="12sp"
           android:textColor="@color/cinza_medio" />
   </LinearLayout>

   <Button
       android:id="@+id/btn_ver_detalhes"
       android:layout_width="wrap_content"
       android:layout_height="36dp"
       android:text="Ver Detalhes"
       android:textSize="12sp"
       android:textColor="@color/branco"
       android:backgroundTint="@color/teal_principal"
       android:layout_alignParentEnd="true"
       android:layout_centerVertical="true" />

</RelativeLayout>
</androidx.cardview.widget.CardView>

<!-- Dúvidas Frequentes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dúvidas Frequentes"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/cinza_escuro"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/branco">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/img_faq"
                    android:layout_width="64dp"
                    android:layout_height="64dp" />
                    <!-- android:src="@drawable/img_faq"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:scaleType="centerCrop"
                    android:background="@drawable/shape_circle" -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tem alguma dúvida sobre o tratamento?"
                    android:textSize="13sp"
                    android:textColor="@color/cinza_escuro"
                    android:layout_toEndOf="@id/img_faq"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="8dp"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/btn_duvidas"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Dúvidas Frequentes"
                    android:textSize="11sp"
                    android:textColor="@color/branco"
                    android:backgroundTint="@color/teal_principal"
                    android:layout_toEndOf="@id/img_faq"
                    android:layout_marginStart="12dp"
                    android:layout_alignParentBottom="true" />

            </RelativeLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>

